
@model List<LibraryManagementSystemWebApplication.Models.Books>
@{
    Layout = "_layoutBooks";
}

@if (TempData["Message"] != null)
{
    <div class="alert alert-success" role="alert">
        @TempData["Message"]
    </div>
}

<tbody>

     @foreach (var iteam in Model ) 
     { 
        <tr>
            <td>
                <span class="custom-checkbox">
                        <input type="checkbox" id="@iteam.Id" name="options[]" value="1">
                    <label for="checkbox2"></label>
                </span>
            </td>
            <td> @iteam.Id</td>
            <td>@iteam.Title</td>
            <td>  @iteam.Author</td>
            <td>@iteam.ISBN</td>
            <td> @iteam.Availability</td>
            <td>

                <a href="#editEmployeeModal" class="edit" data-toggle="modal" data-id="@iteam.Id"><i class="material-icons" data-toggle="tooltip" title="Edit">&#xE254;</i></a>

                @* Direct Delete Without Tonggle  ---*@
                @* <a asp-action="DeleteMyBooks" asp-controller="Books" asp-route-id="@iteam.Id" class="delete"><i class="material-icons" data-toggle="tooltip" title="Delete">&#xE872;</i></a> *@
                
               
                @*  working with ajax code /chat gpt code :::: -------------------------------- *@
                 <a href="#deleteEmployeeModal" class="delete" data-toggle="modal" data-id="@iteam.Id"><i class="material-icons" data-toggle="tooltip" title="Delete">&#xE872;</i></a>
               
                 <span>


@*              
                    <a href="#deleteEmployeeModal(@iteam.Id)" class="delete"  data-toggle="modal"><i class="material-icons" data-toggle="tooltip" title="Delete">&#xE872;</i></a>
*@

@*                  <a id="editEmployeeModal" asp-route-id="@iteam.Id" class="edit" data-toggle="modal"><i class="material-icons" data-toggle="tooltip" title="Edit">&#xE254;</i></a>
                <a asp-action="DeleteBook" asp-controller="Books" id="deleteEmployeeModal" class="delete" data-toggle="modal"><i class="material-icons" data-toggle="tooltip" title="Delete">&#xE872;</i></a>
 *@
                </span>
 
            </td>
        </tr>
    } 

    

</tbody>
<</table> 
<div class="clearfix">
    <div class="hint-text">Showing <b>5</b> out of <b>25</b> entries</div>
    <ul class="pagination">
        <li class="page-item disabled"><a href="#">Previous</a></li>
        <li class="page-item active"><a href="#" class="page-link">1</a></li>
        <li class="page-item"><a href="#" class="page-link">2</a></li>
        <li class="page-item "><a href="#" class="page-link">3</a></li>
        <li class="page-item"><a href="#" class="page-link">4</a></li>
        <li class="page-item"><a href="#" class="page-link">5</a></li>
        <li class="page-item"><a href="#" class="page-link">Next</a></li>
    </ul>
</div>

