    @* <p><strong>Tip:</strong> Use the transition-duration property to determine the speed of the "hover" effect:</p>*@

    <button id="btn" class="button button1"><a asp-controller="Admin" asp-action="Login" style="color:black">Login</a> </button>
    <button id="btn" class="button button2"><a asp-controller="Admin" asp-action="Registration" style="color:black"> Register </a></button>

</div>